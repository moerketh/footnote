# GitHub PAT with repo scope
GITHUB_TOKEN=

# LLM scoring - Tier 1 (local Ollama, OpenAI-compatible endpoint)
LOCAL_OLLAMA_URL=http://host.docker.internal:11434/v1
LOCAL_MODEL=gemma4:26b

# LLM scoring - Tier 2 (Ollama Cloud, OpenAI-compatible endpoint)
CLOUD_OLLAMA_URL=https://ollama.com/v1
CLOUD_MODEL=glm-5.1
CLOUD_API_KEY=

# Scanner
SCAN_INTERVAL_HOURS=6
BACKFILL_DAYS=30

# API
API_HOST=0.0.0.0
API_PORT=8000
